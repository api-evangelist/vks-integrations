{
  "name": "VKSWorkOrder",
  "description": "Manufacturing work order structure",
  "type": "object",
  "fields": [
    {"name": "id", "type": "string", "required": true, "description": "Unique work order ID"},
    {"name": "work_order_number", "type": "string", "required": true, "description": "ERP work order number"},
    {"name": "guidebook_id", "type": "string", "required": true, "description": "Associated guidebook ID"},
    {"name": "guidebook_name", "type": "string", "required": false, "description": "Guidebook name"},
    {"name": "status", "type": "string (enum)", "required": true, "description": "planned|in_progress|completed|on_hold"},
    {"name": "part_number", "type": "string", "required": false, "description": "Part number"},
    {"name": "expected_quantity", "type": "integer", "required": false, "description": "Expected units"},
    {"name": "actual_quantity", "type": "integer", "required": false, "description": "Actual units produced"},
    {"name": "assigned_worker", "type": "string", "required": false, "description": "Worker ID"},
    {"name": "started_at", "type": "string (date-time)", "required": false},
    {"name": "completed_at", "type": "string (date-time)", "required": false},
    {"name": "created_at", "type": "string (date-time)", "required": false},
    {"name": "updated_at", "type": "string (date-time)", "required": false}
  ]
}
